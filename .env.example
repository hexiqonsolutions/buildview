# =============================================================================
# BuildView — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development:
#
#   cp .env.example .env.local
#
# On Vercel, add the same variables in Project Settings → Environment Variables.
# =============================================================================

# -----------------------------------------------------------------------------
# Supabase (required)
# Get these from: Supabase Dashboard → Project Settings → API
# -----------------------------------------------------------------------------

# Public project URL (safe for browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key (safe for browser — RLS enforces access)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Service role key (SERVER ONLY — never expose to the client or commit to git)
# Used for privileged server operations that bypass RLS when needed.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Direct Postgres connection (for npm run db:apply — from Dashboard → Database → URI)
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# -----------------------------------------------------------------------------
# Application URL (required for auth email links in production)
# -----------------------------------------------------------------------------

# Local development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Production example (uncomment and set your Vercel domain):
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Public site URL for SEO (sitemap, Open Graph). Defaults to NEXT_PUBLIC_APP_URL.
# NEXT_PUBLIC_SITE_URL=https://buildview.io

# -----------------------------------------------------------------------------
# Integrations (optional)
# -----------------------------------------------------------------------------

# Background sync security (recommended for cron/webhooks)
# Set this in Vercel/production and use as Authorization: Bearer <CRON_SECRET>
# for internal jobs like /api/internal/sync-users.
# CRON_SECRET=your-random-long-secret

# Calendly — embed scheduler on /contact (use your Calendly inline embed URL)
# NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/your-org/buildview-demo?embed_domain=localhost:3000&embed_type=Inline

# Google Analytics 4 measurement ID
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Resend — contact form email delivery (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_TO_EMAIL=hello@buildview.io
# CONTACT_FROM_EMAIL=BuildView <notifications@yourdomain.com>

# Optional — separate sender for in-app notification emails (falls back to CONTACT_FROM_EMAIL)
# NOTIFICATION_FROM_EMAIL=BuildView Alerts <alerts@yourdomain.com>
